font-family = 'FiraCode Nerd Font Mono'
font-size = 15

keybind = cmd+shift+d=new_split:down
keybind = cmd+shift+v=new_split:right

keybind = ctrl+cmd+h=goto_split:left
keybind = ctrl+cmd+j=goto_split:down
keybind = ctrl+cmd+k=goto_split:up
keybind = ctrl+cmd+l=goto_split:right

keybind = shift+enter=text:\n

shell-integration = detect
desktop-notifications = true
custom-shader = my-shaders/cursor_smear.glsl
